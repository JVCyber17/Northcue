PORT=3000

# Supabase backend configuration.
# Keep the service role key on the server only. Never place it in public HTML/CSS/JS.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# Optional AI pass. The app still falls back safely if this is missing or fails.
OPENAI_API_KEY=your-openai-api-key
CLEARSTEPS_AI_TIMEOUT_MS=25000
CLEARSTEPS_AI_DEBUG=false

# Public MVP safety controls.
RATE_LIMIT_WINDOW_MS=60000
TEMP_FILE_RETENTION_MS=3600000

# Local debugging only. Do not set this in production.
# CLEARSTEPS_ENABLE_FILE_RETENTION=1
